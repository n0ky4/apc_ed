      ],
      "updated": 1775335485073,
      "link": null,
      "locked": false,
      "text": "void f(int a, int b) {\n    int c = a;\n    a = b;\n    b = c;\n}\n\nvoid g(int *c, int n) {\n    c = malloc(sizeof(int) * n);\n}\n\nvoid h(int *h) {\n    *h = 100;\n}\n\nint main() {\n    int a = 1, b = 2, c= 3;\n    int **d;\n\n    d = malloc(sizeof(int*));\n    f(a, b);\n    g(d[1], 1);\n\n    h(*d);\n    free(d);\n\n    printf(\"%d, %d, %d\", a, c, d[1][1]);\n    return 0;\n}\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "void f(int a, int b) {\n    int c = a;\n    a = b;\n    b = c;\n}\n\nvoid g(int *c, int n) {\n    c = malloc(sizeof(int) * n);\n}\n\nvoid h(int *h) {\n    *h = 100;\n}\n\nint main() {\n    int a = 1, b = 2, c= 3;\n    int **d;\n\n    d = malloc(sizeof(int*));\n    f(a, b);\n    g(d[1], 1);\n\n    h(*d);\n    free(d);\n\n    printf(\"%d, %d, %d\", a, c, d[1][1]);\n    return 0;\n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4FpcmH6iFTtKEiOpgwcsK",
      "type": "text",
      "x": 908.4444444444446,
      "y": 90.05555555555554,
      "width": 692.279541015625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 2009557852,
      "version": 926,
      "versionNonce": 451215204,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "Ze9s65dzPPcHePnipwRz7",
          "type": "arrow"
        },
        {
          "id": "X1JNF5VRpcwwGX7MouBXZ",
          "type": "arrow"
        }
      ],
      "updated": 1775335672458,
      "link": null,
      "locked": false,
      "text": "a e b são parâmetros passados por valor (e não por referência).\nO swap é performado normalmente, mas apenas nas variáveis locais.\nComo o intuito era performar um swap por referência, essa função está\nerrada e o valor \"real\" de a e b são inalterados.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "a e b são parâmetros passados por valor (e não por referência).\nO swap é performado normalmente, mas apenas nas variáveis locais.\nComo o intuito era performar um swap por referência, essa função está\nerrada e o valor \"real\" de a e b são inalterados.",
      "autoResize": true,
      "lineHeight": 1.25
    },
